# ─────────────────────────────────────────────────────────────
# Conference Stream — production environment
# On the VPS, copy this to `.env.local` and fill in the real values.
# `.env.local` is gitignored, so secrets never get committed.
# ─────────────────────────────────────────────────────────────

# Owner login password (the built-in super-admin at /admin)
ADMIN_PASSWORD=choose-a-strong-password

# Secret used to sign admin session tokens. Use a long random string.
# Generate one with:  openssl rand -hex 32
ADMIN_SESSION_SECRET=replace-with-openssl-rand-hex-32

# Public site URL — used in invite-email links. Must match your real domain.
NEXT_PUBLIC_BASE_URL=https://watch.dhmm190.com

# Email sending (Google Workspace SMTP for allnations@dhmm190.com).
# SMTP_PASS is a Google "App Password" (16 chars), NOT the normal password.
SMTP_USER=allnations@dhmm190.com
SMTP_PASS=your-16-char-google-app-password
SMTP_FROM=allnations@dhmm190.com

# NOTE: do NOT set DATABASE_URL — leaving it unset uses the built-in SQLite
# file (conference.db), which is what we want on a single VPS.
#
# NOTE: PORT and NODE_ENV are set by PM2 (ecosystem.config.cjs), not here,
# because server.js reads PORT before the .env file is loaded.
